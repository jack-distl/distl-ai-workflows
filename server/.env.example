# MCP Server — Environment Variables
# For local development only. In production, use Google Secret Manager.

# --- Google Ads API ---
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=        # MCC account ID (no dashes)

# --- Google Drive ---
# Option A: Service account (recommended for server deployment)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=     # Path to service account JSON key file

# Option B: OAuth (for local dev / migration from CLI tools)
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=

# Drive folder structure
GOOGLE_DRIVE_ROOT_FOLDER_ID=         # ID of the "Google Ads Reporting" root folder

# --- Server ---
PORT=8000
LOG_LEVEL=INFO
