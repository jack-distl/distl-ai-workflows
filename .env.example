# Copy this file to .env and fill in your values
# cp .env.example .env

OPENAI_API_KEY=
GOOGLE_API_KEY=

# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=        # MCC account ID (no dashes)

# Google Drive (uses OAuth via credentials.json + token.json)
GOOGLE_DRIVE_ROOT_FOLDER_ID=         # ID of the "Google Ads Reporting" root folder

# Operational
TEST_MODE=true                       # true = load sample data, false = call live APIs
