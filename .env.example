# Copy this file to .env and fill in your values
# cp .env.example .env

OPENAI_API_KEY=
GOOGLE_API_KEY=

# MCP Server (set by admin — points to the deployed MCP server)
# Google Ads and Drive credentials are held server-side, not here.
DISTL_MCP_SERVER_URL=
DISTL_MCP_API_KEY=                   # Shared API key for MCP server auth

# Required for Figma export (tools/export_to_figma.py)
FIGMA_ACCESS_TOKEN=your_figma_personal_access_token
